syncUpdate() {
  local source="$HOME/Documents/bash/bash-scripts/update.sh"
  local target="./scripts/update.sh"
  
  if [ ! -f "$source" ]; then
    echo "❌ Source file not found: $source"
    return 1
  fi
  
  cp "$source" "$target"
  chmod +x "$target"
  echo "✅ Updated: $target"
}

function rnst() {
    perl-rename '
        s/[ ,()]+/-/g;
        s/-+/-/g;
        s/^-//;
        s/-$//;
    ' -- *
}

function rndg() {
    digits=$1
    if [ -z "$digits" ]; then
        digits=2
    fi
    perl-rename 's/(\d+)/sprintf("%0'${digits}'d", $1)/e' *
    # perl-rename 's/(\d+)/sprintf("%03d", $1)/e' *
}

