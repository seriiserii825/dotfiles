function rmnl() {
  # remove everything if exists
  [ -d "node_modules" ] && rm -rf node_modules
  [ -f "package-lock.json" ] && rm -f package-lock.json
  [ -f "yarn.lock" ] && rm -f yarn.lock
  [ -f "pnpm-lock.yaml" ] && rm -f pnpm-lock.yaml
  [ -f "bun.lock" ] && rm -f bun.lock
  [ -d ".nuxt" ] && rm -rf .nuxt
}
function grmnl() {
  git rm --cached -rf --ignore-unmatch node_modules
  git rm --cached -f  --ignore-unmatch package-lock.json
  git rm --cached -f  --ignore-unmatch yarn.lock
  git rm --cached -f  --ignore-unmatch pnpm-lock.yaml
  git rm --cached -f  --ignore-unmatch bun.lock
  git rm --cached -rf --ignore-unmatch .nuxt
}
